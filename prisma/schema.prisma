generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ AUTH MODELS ============

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  plan          String    @default("starter") // starter, pro, business, enterprise
  credits       Int       @default(100)
  storageUsed   BigInt    @default(0)
  storageLimit  BigInt    @default(1073741824) // 1GB default
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  projects Project[]
  exports  Export[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ APP MODELS ============

model Project {
  id                String   @id @default(cuid())
  title             String   @default("Untitled Project")
  userId            String
  status            String   @default("uploading") // uploading, analyzing, processing, ready, exported, failed
  niche             String?
  duration          Float    @default(0)
  fileSize          BigInt   @default(0)
  fileUrl           String?
  fileKey           String?
  thumbnailUrl      String?
  viralityScore     Float?
  retentionScore    Float?
  hookScore         Float?
  progress          Int      @default(0)
  exportedPlatforms String[] @default([])

  // AI Analysis Results
  transcription String? @db.Text
  language      String?
  segments      Json?   // Array of {start, end, text}
  analysisData  Json?   // Full analysis object
  editingStyle  Json?   // Detected editing style

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exports Export[]

  @@index([userId])
  @@index([status])
}

model Export {
  id         String   @id @default(cuid())
  projectId  String
  userId     String
  platform   String   // instagram_reels, youtube_shorts, tiktok, etc.
  ratio      String   // 9:16, 16:9, 1:1, 4:5
  resolution String   @default("1080p")
  fps        Int      @default(30)
  status     String   @default("queued") // queued, processing, complete, failed
  progress   Int      @default(0)
  fileUrl    String?
  fileKey    String?
  fileSize   BigInt?
  error      String?
  createdAt  DateTime @default(now())
  completedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([status])
}
